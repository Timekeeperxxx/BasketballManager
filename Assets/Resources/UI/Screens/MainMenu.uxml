<ui:UXML xmlns:ui="UnityEngine.UIElements">
    <Style src="project://database/Assets/Resources/UI/Theme/theme.uss" />
    <Style src="project://database/Assets/Resources/UI/Screens/MainMenu.uss" />
    <ui:VisualElement name="main-menu" class="main-menu screen-page">
        <ui:VisualElement class="main-menu__bg" picking-mode="Ignore" />

        <ui:VisualElement class="main-menu__brand">
            <ui:Label text="BASKETBALL" class="main-menu__title-1" />
            <ui:Label text="MANAGER" class="main-menu__title-2" />
            <ui:Label text="赛季模拟 · 阵容经营" class="main-menu__subtitle" />
        </ui:VisualElement>

        <ui:VisualElement class="main-menu__actions">
            <ui:Button name="btn-season"  text="赛  季  模  式" class="btn btn--primary btn--lg main-menu__btn" />
            <ui:Button name="btn-options" text="游  戏  选  项" class="btn btn--lg main-menu__btn" />
            <ui:Button name="btn-quit"    text="退  出  游  戏" class="btn btn--ghost btn--lg main-menu__btn" />
        </ui:VisualElement>

        <ui:Label name="version-label" text="v0.1 · 阶段一" class="main-menu__version" />
    </ui:VisualElement>
</ui:UXML>
