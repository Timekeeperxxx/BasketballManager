<ui:UXML xmlns:ui="UnityEngine.UIElements">
    <Style src="project://database/Assets/Resources/UI/Theme/theme.uss" />
    <Style src="project://database/Assets/Resources/UI/Screens/SeasonScreen.uss" />
    <ui:VisualElement name="season-screen" class="screen-page season-screen">

        <!-- 顶栏：返回 + 赛季信息 + 操作按钮 -->
        <ui:VisualElement class="page-topbar">
            <ui:Button name="btn-back" text="← 返回主菜单" class="btn btn--back" />
            <ui:VisualElement class="page-topbar__title-block">
                <ui:Label text="赛季模式" class="h2" />
                <ui:Label name="season-name" text="" class="caption" />
            </ui:VisualElement>
            <ui:VisualElement class="page-topbar__actions">
                <ui:Button name="btn-new" text="创建新赛季" class="btn topbar-btn" />
                <ui:Button name="btn-sim-next" text="模拟下一场" class="btn btn--primary topbar-btn" />
                <ui:Button name="btn-sim-all" text="模拟剩余" class="btn topbar-btn" />
                <ui:Button name="btn-start-playoffs" text="开始季后赛" class="btn btn--primary topbar-btn" />
                <ui:Button name="btn-next-season" text="下一赛季" class="btn btn--primary topbar-btn" />
            </ui:VisualElement>
        </ui:VisualElement>

        <!-- 一级 tab 条 -->
        <ui:VisualElement class="tabs">
            <ui:Button name="tab-overview"  text="总  览"   class="tab tab--active" />
            <ui:Button name="tab-standings" text="积  分  榜" class="tab" />
            <ui:Button name="tab-schedule"  text="赛  程"   class="tab" />
            <ui:Button name="tab-data"      text="数  据"   class="tab" />
        </ui:VisualElement>

        <!-- tab 内容容器 -->
        <ui:VisualElement name="tab-content" class="tab-content">

            <!-- ============ 总览 ============ -->
            <ui:VisualElement name="page-overview" class="tab-page">
                <ui:VisualElement class="card overview__last-card">
                    <ui:Label text="最近一场" class="card-title" />
                    <ui:Label name="ov-last-headline" text="尚未模拟任何比赛。" class="overview__last-headline muted" />
                    <ui:Label name="ov-last-meta"     text=""                   class="overview__last-meta" />
                </ui:VisualElement>

                <ui:VisualElement class="overview__row">
                    <ui:VisualElement class="card overview__recent-card">
                        <ui:Label text="近期比赛" class="card-title" />
                        <ui:VisualElement name="ov-recent-list" class="overview__recent-list" />
                        <ui:Label name="ov-recent-empty" text="还没有已完成的比赛。" class="muted caption" />
                    </ui:VisualElement>

                    <ui:VisualElement class="card overview__standout-card">
                        <ui:Label text="突出表现" class="card-title" />
                        <ui:VisualElement name="ov-standout-list" class="overview__standout-list" />
                        <ui:Label name="ov-standout-empty" text="还没有可统计的球员数据。" class="muted caption" />
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>

            <!-- ============ 积分榜 ============ -->
            <ui:VisualElement name="page-standings" class="tab-page tab-page--hidden">
                <ui:VisualElement class="card card--fill">
                    <ui:VisualElement class="card-header">
                        <ui:Label text="积分榜" class="card-title" />
                        <ui:Label name="standings-count" text="" class="caption" />
                    </ui:VisualElement>
                    <ui:MultiColumnListView name="standings" show-foldout-header="false" reorderable="false" show-border="false" />
                </ui:VisualElement>
            </ui:VisualElement>

            <!-- ============ 赛程 ============ -->
            <ui:VisualElement name="page-schedule" class="tab-page tab-page--hidden">
                <ui:VisualElement class="card card--fill">
                    <ui:VisualElement class="card-header">
                        <ui:Label text="赛程" class="card-title" />
                        <ui:Label name="schedule-count" text="" class="caption" />
                    </ui:VisualElement>
                    <ui:MultiColumnListView name="schedule" show-foldout-header="false" reorderable="false" show-border="false" />
                    <ui:VisualElement name="bracket-container" class="bracket-container" />
                </ui:VisualElement>
            </ui:VisualElement>

            <!-- ============ 数据 ============ -->
            <ui:VisualElement name="page-data" class="tab-page tab-page--hidden">
                <!-- 相位切换（常规赛/季后赛，仅季后赛阶段可见） -->
                <ui:VisualElement name="stats-phase-row" class="tabs tabs--sub">
                    <ui:Button name="statphase-regular" text="常  规  赛" class="tab tab--sub tab--active" />
                    <ui:Button name="statphase-playoff" text="季  后  赛" class="tab tab--sub" />
                </ui:VisualElement>
                <!-- 二级 tab -->
                <ui:VisualElement class="tabs tabs--sub">
                    <ui:Button name="subtab-players" text="球  员" class="tab tab--sub tab--active" />
                    <ui:Button name="subtab-teams"   text="球  队" class="tab tab--sub" />
                </ui:VisualElement>

                <ui:VisualElement name="subpage-players" class="tab-page">
                    <ui:VisualElement class="card card--fill">
                        <ui:VisualElement class="card-header">
                            <ui:Label text="球员场均数据" class="card-title" />
                            <ui:Label name="players-count" text="" class="caption" />
                        </ui:VisualElement>
                        <ui:MultiColumnListView name="players-stats" show-foldout-header="false" reorderable="false" show-border="false" />
                    </ui:VisualElement>
                </ui:VisualElement>

                <ui:VisualElement name="subpage-teams" class="tab-page tab-page--hidden">
                    <ui:VisualElement class="card card--fill">
                        <ui:VisualElement class="card-header">
                            <ui:Label text="球队数据" class="card-title" />
                            <ui:Label name="teams-count" text="" class="caption" />
                        </ui:VisualElement>
                        <ui:MultiColumnListView name="teams-stats" show-foldout-header="false" reorderable="false" show-border="false" />
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>

        </ui:VisualElement>

        <!-- ===== 赛前决策面板 ===== -->
        <ui:VisualElement name="pregame-modal-overlay" class="match-modal-overlay">
            <ui:VisualElement name="pregame-modal" class="pregame-modal">
                <ui:VisualElement class="pregame-modal__header">
                    <ui:VisualElement class="pregame-modal__title-block">
                        <ui:Label name="pregame-title" text="" class="pregame-modal__title" />
                        <ui:Label name="pregame-matchup" text="" class="pregame-modal__matchup" />
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:Label text="轮换顺序  ·  调整↑↓改变球员上场时间（前5名为首发）" class="pregame-modal__hint" />
                <ui:ScrollView name="pregame-player-scroll" class="pregame-modal__scroll">
                    <ui:VisualElement name="pregame-player-list" class="pregame-modal__list" />
                </ui:ScrollView>
                <ui:VisualElement class="pregame-modal__footer">
                    <ui:Button name="btn-pregame-skip" text="跳过调整，直接模拟" class="btn" />
                    <ui:Button name="btn-pregame-confirm" text="确认阵容，开始比赛" class="btn btn--primary" />
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>

        <!-- ===== 赛季间总结弹窗 ===== -->
        <ui:VisualElement name="offseason-overlay" class="match-modal-overlay">
            <ui:VisualElement class="offseason-popup">
                <ui:VisualElement class="offseason-popup__header">
                    <ui:Label name="offseason-title" text="赛季总结" class="offseason-popup__title" />
                    <ui:Label name="offseason-subtitle" text="" class="caption" />
                </ui:VisualElement>
                <ui:ScrollView name="offseason-scroll" class="offseason-scroll" />
                <ui:VisualElement class="offseason-popup__footer">
                    <ui:Button name="btn-offseason-confirm" text="进入新赛季" class="btn btn--primary" />
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>

        <!-- ===== 比赛结果弹窗 ===== -->
        <ui:VisualElement name="match-modal-overlay" class="match-modal-overlay">
            <ui:VisualElement name="match-modal" class="match-modal">
                <ui:VisualElement class="match-modal__header">
                    <ui:VisualElement class="match-modal__score-block">
                        <ui:Label name="modal-score-headline" text="" class="match-modal__headline" />
                        <ui:Label name="modal-score-quarters" text="" class="match-modal__quarters" />
                    </ui:VisualElement>
                    <ui:Button name="modal-close-btn" text="✕" class="match-modal__close-btn" />
                </ui:VisualElement>
                <ui:VisualElement class="match-modal__tab-bar">
                    <ui:Button name="modal-tab-pbp"    text="📡 播报"  class="modal-tab modal-tab--active" />
                    <ui:Button name="modal-tab-player" text="球员数据" class="modal-tab" />
                    <ui:Button name="modal-tab-team"   text="球队数据" class="modal-tab" />
                </ui:VisualElement>
                <ui:VisualElement name="modal-tab-content" class="match-modal__content" />
            </ui:VisualElement>
        </ui:VisualElement>

        <!-- ===== 自由球员市场 overlay ===== -->
        <ui:VisualElement name="fa-overlay" class="match-modal-overlay" style="display: none;">
            <ui:VisualElement class="offseason-popup fa-modal">
                <ui:VisualElement class="offseason-popup__header">
                    <ui:Label text="自由球员市场" class="offseason-popup__title" />
                    <ui:Label name="fa-cap-space" text="薪资帽剩余：— M" class="caption" />
                </ui:VisualElement>
                <ui:ScrollView name="fa-list" class="offseason-scroll" />
                <ui:VisualElement class="offseason-popup__footer">
                    <ui:Button name="btn-fa-done" text="完成签约，进入选秀" class="btn btn--primary" />
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>

        <!-- ===== 选秀大会 overlay ===== -->
        <ui:VisualElement name="draft-overlay" class="match-modal-overlay" style="display: none;">
            <ui:VisualElement class="offseason-popup draft-modal">
                <ui:VisualElement class="offseason-popup__header">
                    <ui:Label text="选秀大会" class="offseason-popup__title" />
                    <ui:Label name="draft-pick-info" text="" class="caption" />
                </ui:VisualElement>
                <ui:VisualElement class="draft-content">
                    <ui:ScrollView name="draft-log" class="draft-log" />
                    <ui:ScrollView name="draft-prospects" class="draft-prospects" />
                </ui:VisualElement>
                <ui:VisualElement class="offseason-popup__footer">
                    <ui:Button name="btn-draft-auto" text="AI 代选" class="btn" />
                    <ui:Button name="btn-draft-done" text="进入新赛季" class="btn btn--primary" style="display: none;" />
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
